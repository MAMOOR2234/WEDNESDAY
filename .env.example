# Wednesday AI Assistant - Environment Configuration
# Copy this to .env and fill in your values

# Gemini API Key (required)
# Get from: https://makersuite.google.com/app/apikeys
GEMINI_API_KEY=AIzaSyCtm5_lay1-nBLX2NCgyQUsRQbtQsL4ulE

# Gemini Model
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash (if available)
GEMINI_MODEL=gemini-1.5-flash

# Speech Recognition Engine
# Options: faster-whisper, speech_recognition
SPEECH_ENGINE=faster-whisper

# Speech Language
# Format: language-COUNTRY (e.g., en-US, en-GB, es-ES)
SPEECH_LANGUAGE=en-US

# Speech Recognition Timeout (seconds)
SPEECH_TIMEOUT=10

# Text-to-Speech Engine
# Options: pyttsx3, edge-tts
TTS_ENGINE=pyttsx3

# TTS Speed (words per minute)
# Range: 50-300, default: 150
TTS_SPEED=150

# TTS Voice
# pyttsx3: "default", "male", "female"
# edge-tts: "en-US-AriaNeural", "en-US-GuyNeural", etc.
TTS_VOICE=default

# Optional: Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
